# Toolathlon Environment Configuration
# =====================================
# Copy this file to .env in the project root and fill in your values.
# The prefix.sh script will attempt to load .env automatically.
#
# Or export these variables directly before running prefix.sh

# ============================================
# 🤖 LLM API (REQUIRED)
# ============================================
# Get your key from: https://openrouter.ai/keys
TOOLATHLON_OPENAI_API_KEY=sk-or-v1-<OPENROUTER_API_KEY_PLACEHOLDER>

# Default model to use (can be overridden per-run)
TOOLATHLON_MODEL=claude-4.5-sonnet-0929
TOOLATHLON_PROVIDER=openrouter

# ============================================
# 🟢 SIMPLE SETUP (API Key Only)
# ============================================

# HuggingFace - https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# Weights & Biases - https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here

# GitHub - https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ALLOWED_REPOS=*
GITHUB_READ_ONLY=0

# Serper (Google Search) - https://serper.dev/
SERPER_API_KEY=your_serper_key_here

# ============================================
# 🟡 MEDIUM SETUP (OAuth/Service Account)
# ============================================

# Google Cloud Console API Key - for YouTube, etc.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=AIzaSy_your_key_here

# Google Cloud Platform (GCP) - for BigQuery, Cloud Storage, etc.
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_PATH=configs/gcp-service_account.keys.json

# Google Sheets/Drive (OAuth2 Credentials)
# Create OAuth Client ID at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH2_CREDENTIALS_PATH=configs/google_credentials.json
GOOGLE_OAUTH2_TOKEN_PATH=configs/google_credentials.json
GOOGLE_SHEETS_FOLDER_ID=

# Notion - https://www.notion.so/my-integrations
NOTION_INTEGRATION_KEY=ntn_your_key_here
NOTION_PAGE_IDS=page-id-1,page-id-2

# Snowflake (optional)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# ============================================
# 🔴 COMPLEX SETUP (Infrastructure Required)
# ============================================

# Kubernetes (path to kubeconfig file)
KUBECONFIG_PATH=deployment/k8s/configs/cluster1-config.yaml

# ============================================
# 📁 PATH CONFIGURATION (usually don't need to change)
# ============================================
# TOOLATHLON_ROOT=/path/to/DikaNong
# TOOLATHLON_CACHE_DIR=/hy-tmp/toolathlon_cache
# TOOLATHLON_HOME=/hy-tmp/toolathlon_home

# ============================================
# ⚙️ EXECUTION SETTINGS (optional tweaks)
# ============================================
# TOOLATHLON_MAX_TURNS=50
# TOOLATHLON_MAX_STEPS=50
# TOOLATHLON_TASK_TIMEOUT=600
# TOOLATHLON_AGENT_TEMPERATURE=0.0  # Default: 0.0 for deterministic output
# TOOLATHLON_AGENT_MAX_TOKENS=4096
